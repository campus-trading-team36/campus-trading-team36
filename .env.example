# server
PORT=8080
HOST=0.0.0.0

# environment - set to "production" to hide demo helpers (e.g. verification code in API response)
NODE_ENV=development

# admin seed account (used on first DB init only)
# in production you MUST override these
ADMIN_EMAIL=admin@liverpool.ac.uk
ADMIN_PASSWORD=change-me-please
ADMIN_USERNAME=admin

# allowed university email domains, comma separated
EMAIL_DOMAINS=liverpool.ac.uk,student.liverpool.ac.uk

# uploads
MAX_FILE_SIZE=5242880
MAX_IMAGES_PER_PRODUCT=5

# request body size limit (DoS protection)
JSON_BODY_LIMIT=1mb

# admin moderation - "on" or "off"
# when on, new listings need admin approval before they appear publicly
MODERATION=on

# CORS - comma separated origins, omit to allow all
# CORS_ORIGIN=https://yourdomain.example
